class Solution {
public:

    int reverseNum(int x){
        long rev = 0;
        if(x<0){
            return false;
        }
        while(x>0){
            int lastdig = x%10;
            rev = (rev*10)+lastdig;
            if(rev>INT_MAX || rev<INT_MIN){
                return 0;
            }
            x = x/10;
        }
        return (rev == x);

    }
    bool isPalindrome(int x) {
        return reverseNum(x);       
    }
};