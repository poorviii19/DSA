class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        int windowSum = 0;
        for(int i =0;i<k;i++){
            windowSum += nums[i];
        }

        int maxAvg = windowSum;

        for(int i = k;i<nums.size();i++){
            windowSum+=nums[i];
            windowSum -= nums[i-k];

            maxAvg = max(maxAvg, windowSum);
        }

        return (double)maxAvg/k;
    }
};